# ETWIN Commerce — frontend env
# Set this to your live PHP API base URL.
# When empty, the frontend runs in DEMO MODE using local mock data — DO NOT deploy that way.
#
# Local Laragon dev:
#   - Built-in PHP server (recommended, default below): http://127.0.0.1:8080
#       Run from Laragon terminal:  php -S 127.0.0.1:8080 -t backend-php/public
#   - Apache vhost (Laragon .test domain):              http://etwin-api.test
#
# Production: e.g. https://api.etwin.app
#
# After changing this value, RESTART the Vite dev server — Vite reads .env only at startup.
VITE_PHP_API_BASE="http://127.0.0.1:8080"
