# ETWIN Commerce — backend env (copy to backend-php/.env for local dev)
# Real OS environment variables ALWAYS override values in this file.

APP_ENV=development

# ── Database (Laragon defaults: root user, empty password, localhost MySQL) ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=etwin_commerce
DB_USER=root
DB_PASS=

# ── Auth ──
# In dev a placeholder is fine; in production set APP_ENV=production and use
#   php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=dev-only-secret-change-me-please-replace-now-32+chars

# ── Telegram (optional in dev — leave blank if you don't use it) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── CORS ──
# Vite dev server default. Add the .test host here too if you serve the frontend
# through Laragon (comma-separated origins are NOT supported by the browser; use
# the single origin you actually load the app from).
CORS_ALLOW_ORIGIN=http://localhost:5173

# ── Frontend URL (used in emails, links) ──
APP_BASE_URL=http://localhost:5173

# ── HTTPS — keep false for local dev ──
FORCE_HTTPS=false
